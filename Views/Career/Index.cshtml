<!-- Registration Modal -->
<div class="modal fade" id="CVUploadModal" tabindex="-1" aria-labelledby="CVUploadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="CVUploadController" asp-action="Upload" method="post">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Drop Your CV</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label>Full Name</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-2">
                        <label>Contact Number</label>
                        <input asp-for="ContactNumber" class="form-control" required />
                        <span asp-validation-for="ContactNumber" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label>Email</label>
                        <input asp-for="Email" type="email" class="form-control" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <label>Upload Your CV</label>
                    <div class="input-group">
                        
                        <input  type="file" class="form-control" placeholder="Upload a File *" aria-label="File Upload" aria-describedby="basic-addon2"> 
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger w-25" type="submit">Send</button>
                </div>
            </form>
        </div>
    </div>
</div>