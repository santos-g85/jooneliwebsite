<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Jooneli Inc</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/jooneliwebsite.styles.css" asp-append-version="true" />

    <!--bot-->
    <meta name="keywords" content="Jooneli Inc" />
    <meta name="robots" content="index, follow" />

    <meta name="title" content="Jooneli Inc" />
    <meta name="description" content="360cbs trading system." />


    <!-- meta-->
    <meta property="og:title" content="Jooneli Inc" />
    <meta property="og:description" content="Jooneli Inc"/>
    <meta property="og:type" content="website" />
    <meta property="og:url" content="http://jooneli.com/" />
    <meta property="og:image" content="http://jooneli.com/" />
    <meta property="og:image:alt" content="jooneli Inc" />

    <!-- twitter meta-->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="jooneli Inc" />
    <meta name="twitter:description" content="jooneli Inc" />
    <meta name="twitter:image" content="http://jooneli.com/images/" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap JS (with Popper.js for the carousel) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

   
</head>
<body>

    <header class="mt-0 mt-md-4">
        <nav class="navbar navbar-expand-sm navbar-light mb-3 w-100 custom-width-md-75 mx-auto shadow-sm rounded-4">
            <div class="container-fluid">
                <a class="navbar-brand fs-3" asp-area="" asp-controller="Home" asp-action="Index">Jooneli</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrolling" aria-controls="offcanvasScrolling">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 d-flex justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fs-4" asp-area="" asp-controller="About" asp-action="Index">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Business" asp-action="Index">Business</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Career" asp-action="Index">Career</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Contact" asp-action="Index">Get in Touch</a>
                        </li>
                    </ul>
                </div>

                

            </div>
        </nav>
    </header>

  
    <div class="offcanvas offcanvas-start custom-offcanvas" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling" aria-labelledby="offcanvasScrollingLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title fs-3" id="offcanvasScrollingLabel">Jooneli</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link text-dark fs-4 " asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fs-4" asp-area="" asp-controller="About" asp-action="Index">About Us</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Business" asp-action="Index">Business</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Career" asp-action="Index">Career</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark fs-4" asp-area="" asp-controller="Contact" asp-action="Index">Get in Touch</a>
                </li>
            </ul>
        </div>
    </div>

    <div class="container custom-width-md-75 main-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-secondary"> 
         <div class="container"> 
            &copy; 2025 - jooneliwebsite - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> 
        </div> 
     </footer> 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


